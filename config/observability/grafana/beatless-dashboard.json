{
  "dashboard": {
    "id": null,
    "uid": "beatless-v4",
    "title": "Beatless RawCli - Runtime + Entropy",
    "timezone": "Asia/Shanghai",
    "refresh": "30s",
    "schemaVersion": 39,
    "version": 1,
    "panels": [
      {
        "type": "timeseries",
        "title": "Queue Depth & Running Tasks",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          { "expr": "rawcli_queue_depth", "legendFormat": "Queue Depth", "refId": "A" },
          { "expr": "rawcli_running_results", "legendFormat": "Running", "refId": "B" }
        ]
      },
      {
        "type": "gauge",
        "title": "Fail Rate (rolling window)",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "targets": [{ "expr": "rawcli_window_fail_rate", "refId": "A" }]
      },
      {
        "type": "timeseries",
        "title": "ACK Latency (ms)",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
        "targets": [
          { "expr": "rawcli_ack_latency_ms_avg", "legendFormat": "Avg", "refId": "A" },
          { "expr": "rawcli_ack_latency_ms_p95", "legendFormat": "P95", "refId": "B" }
        ]
      },
      {
        "type": "timeseries",
        "title": "Dispatch Duration (sec)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          { "expr": "rawcli_dispatch_duration_sec_avg", "legendFormat": "Avg", "refId": "A" },
          { "expr": "rawcli_dispatch_duration_sec_p95", "legendFormat": "P95", "refId": "B" }
        ]
      },
      {
        "type": "stat",
        "title": "Receipt Pass Rate",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [{ "expr": "rawcli_receipt_pass_rate", "refId": "A" }]
      },
      {
        "type": "gauge",
        "title": "Queue Saturation %",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [{ "expr": "rawcli_queue_saturation_pct", "refId": "A" }]
      },
      {
        "type": "timeseries",
        "title": "Convergence Ratio (Entropy)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [{ "expr": "rawcli_entropy_convergence_ratio", "legendFormat": "Ratio", "refId": "A" }]
      },
      {
        "type": "timeseries",
        "title": "Ideas vs Decisions",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
        "targets": [
          { "expr": "rawcli_entropy_idea_count", "legendFormat": "Ideas", "refId": "A" },
          { "expr": "rawcli_entropy_decision_count", "legendFormat": "Decisions", "refId": "B" }
        ]
      },
      {
        "type": "stat",
        "title": "Explore Blocked",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
        "targets": [{ "expr": "rawcli_entropy_explore_blocked", "refId": "A" }]
      },
      {
        "type": "bargauge",
        "title": "Anthropic Budget (Today)",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
        "targets": [
          { "expr": "rawcli_anthropic_calls_today{model=\"opus\"}", "legendFormat": "Opus", "refId": "A" },
          { "expr": "rawcli_anthropic_calls_today{model=\"sonnet\"}", "legendFormat": "Sonnet", "refId": "B" }
        ]
      },
      {
        "type": "piechart",
        "title": "Failure Types (Window)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [{ "expr": "rawcli_window_failure_type_total", "legendFormat": "{{failure_type}}", "refId": "A" }]
      },
      {
        "type": "timeseries",
        "title": "Queue Lag (ms)",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          { "expr": "rawcli_queue_lag_ms_avg", "legendFormat": "Avg", "refId": "A" },
          { "expr": "rawcli_queue_lag_ms_p95", "legendFormat": "P95", "refId": "B" }
        ]
      }
    ]
  },
  "overwrite": true
}
